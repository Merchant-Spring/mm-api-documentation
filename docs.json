{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "MerchantSpring Public API",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#3B5BDB",
    "light": "#748ffc",
    "dark": "#2f4ac7"
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": true
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "authentication",
              "quickstart"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/reports",
              "guides/profitability",
              "guides/conventions"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "MerchantSpring API",
            "openapi": "api-reference/openapi.json"
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@merchantspring.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://developer.merchantspring.io/dashboard"
    }
  },
  "footer": {
    "socials": {
      "website": "https://merchantspring.io",
      "linkedin": "https://www.linkedin.com/company/merchantspring/",
      "facebook": "https://www.facebook.com/MerchantSpring/",
      "youtube": "https://www.youtube.com/@merchantspring"
    }
  }
}
